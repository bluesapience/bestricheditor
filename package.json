{
  "name": "bestricheditor",
  "version": "0.1.0",
  "description": "A Notion-like rich text editor — Native JS, no frameworks",
  "type": "module",
  "main": "dist/bre.umd.js",
  "module": "dist/bre.esm.js",
  "exports": {
    ".": {
      "import": "./dist/bre.esm.js",
      "require": "./dist/bre.umd.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "rollup -c --watch",
    "build": "BUILD=production rollup -c",
    "preview": "serve . -p 4000"
  },
  "dependencies": {
    "dompurify": "^3.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-livereload": "^2.0.0",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-serve": "^2.0.0",
    "serve": "^14.0.0"
  }
}
